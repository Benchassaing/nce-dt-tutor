NOHUP=1

# ============================================
# NCE DT Tutor - Environment Variables
# Copy to .env and fill in your values
# ============================================

# -----------------------------------------------------------------------------
# DATABASE (Neon PostgreSQL - Free Tier: 0.5 GB)
# Get from: https://neon.tech → Project → Connection Details → Pooled connection
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/nce_dt_tutor?sslmode=require"

# -----------------------------------------------------------------------------
# CLERK AUTHENTICATION (Free: 10,000 MAU)
# Get from: https://clerk.com → Application → API Keys
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/onboarding"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# -----------------------------------------------------------------------------
# AI PROVIDER (Choose ONE)
# -----------------------------------------------------------------------------

# Option A: Anthropic Direct (Free tier: $5 credit)
ANTHROPIC_API_KEY="sk-ant-..."

# Option B: OpenRouter (Free models available, e.g., meta-llama/llama-3.1-8b-instruct:free)
# OPENROUTER_API_KEY="sk-or-..."
# OPENROUTER_MODEL="meta-llama/llama-3.1-8b-instruct:free"

# -----------------------------------------------------------------------------
# SUPABASE VECTOR DATABASE (Free: 500 MB + pgvector)
# Get from: https://supabase.com → Project → Settings → API
# -----------------------------------------------------------------------------
SUPABASE_URL="https://xxxxxxxxxx.supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."  # Service role key (keep secret!)

# -----------------------------------------------------------------------------
# FILE UPLOAD (Optional - Supabase Storage Free: 1 GB)
# -----------------------------------------------------------------------------
# SUPABASE_STORAGE_BUCKET="nce-uploads"

# Alternative: UploadThing (Free: 2 GB)
# UPLOADTHING_SECRET="sk_..."
# UPLOADTHING_APP_ID="..."

# -----------------------------------------------------------------------------
# APP CONFIGURATION
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"  # Change to https://your-app.vercel.app in production
NODE_ENV="development"

# -----------------------------------------------------------------------------
# OPTIONAL: REDIS (Upstash Free: 10K requests/day)
# -----------------------------------------------------------------------------
# REDIS_URL="redis://default:xxx@xxx.upstash.io:6379"

# -----------------------------------------------------------------------------
# OPTIONAL: ANALYTICS (PostHog Free: 1M events/month)
# -----------------------------------------------------------------------------
# POSTHOG_KEY="phc_..."
# POSTHOG_HOST="https://app.posthog.com"

# -----------------------------------------------------------------------------
# OPTIONAL: EMAIL (Resend Free: 3,000 emails/month)
# -----------------------------------------------------------------------------
# RESEND_API_KEY="re_..."
# EMAIL_FROM="NCE DT Tutor <noreply@yourdomain.com>"